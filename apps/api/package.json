{
  "name": "@consensus/api",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent Consensus API server powered by Hono",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
